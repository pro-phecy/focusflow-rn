# NeonDB — copy your connection string from https://neon.tech dashboard
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/focusflow?sslmode=require"

# JWT secrets — generate strong random strings, e.g.: openssl rand -hex 64
JWT_ACCESS_SECRET="your-access-secret-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"

# Server
PORT=4000
NODE_ENV=development

# CORS — set to your Expo dev client origin or "*" for dev
ALLOWED_ORIGINS="*"
